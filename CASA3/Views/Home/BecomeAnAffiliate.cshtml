@{
    ViewData["Title"] = "Become an Affiliate";
}

<!-- Hero Section -->
<section class="relative h-[85vh] overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/affliate-hero.webp');"></div>

    <!-- Overlay (optional, for better text readability) -->
    <div class="absolute inset-0 bg-black/10"></div>

    <!-- Content -->
    <div class="relative z-10 h-full flex items-center">
        <div class="max-w-7xl mx-auto px-6 w-full">
            <div class="max-w-md">
                <!-- Main Title -->
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-4" style="color: #4A4A4A;">
                </h1>

                <!-- Subtitle -->
                <p class="text-2xl md:text-3xl lg:text-4xl font-normal" style="color: #7A7A7A;">
                </p>
            </div>
        </div>
    </div>
</section>


<!-- Affiliate Registration Section (Direct Form) -->
<section class="py-16 md:py-24 bg-gray-950">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <div class="mb-10 text-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">
                Become an Affiliate
            </h2>
            <p class="text-lg text-gray-300 max-w-3xl mx-auto leading-relaxed">
                Owning a business with independent financial benefits sets you on the path to becoming a fulfilled entrepreneur.
                Complete the form below to join our Affiliate program and secure a lifetime of unlimited income.
            </p>
        </div>

        <div class="rounded-2xl shadow-2xl border border-gray-800/70 bg-gradient-to-br from-gray-900 via-gray-950 to-black/90 p-6 md:p-8"
             style="background-image: url('/images/affliate-form-bg.webp'); background-size: cover; background-position: center;">
            <div class="bg-black/70 rounded-2xl p-6 md:p-8">
                <form id="affiliateRegistrationForm" class="space-y-4">
                    <!-- First Name and Last Name Row -->
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold mb-2" style="color: #b39359;">First Name <span class="text-red-500">*</span></label>
                            <input type="text" id="aff_firstName" name="FirstName" placeholder="First Name" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Last Name <span class="text-red-500">*</span></label>
                            <input type="text" id="aff_lastName" name="LastName" placeholder="Last Name" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                        </div>
                    </div>

                    <!-- Email Address -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Email Address <span class="text-red-500">*</span></label>
                        <input type="email" id="email" name="Email" placeholder="Email Address" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- Phone -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Phone <span class="text-red-500">*</span></label>
                        <input type="tel" id="phone" name="Phone" placeholder="0802 123 4567" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- Street Address -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Street Address <span class="text-red-500">*</span></label>
                        <input type="text" id="streetAddress" name="StreetAddress" placeholder="Street Address" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- State/Province -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">State/Province</label>
                        <input type="text" id="stateProvince" name="StateProvince" placeholder="State/Province" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" />
                    </div>

                    <!-- Country -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Country</label>
                        <select id="country" name="Country" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400">
                            <option value="">Select country</option>
                            <option value="Nigeria">Nigeria</option>
                            <option value="Ghana">Ghana</option>
                            <option value="Kenya">Kenya</option>
                            <option value="South Africa">South Africa</option>
                            <option value="Uganda">Uganda</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <!-- Account Name -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Account Name <span class="text-red-500">*</span></label>
                        <input type="text" id="accountName" name="AccountName" placeholder="Account Name" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- Bank Name -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Bank Name <span class="text-red-500">*</span></label>
                        <input type="text" id="bankName" name="BankName" placeholder="Bank Name" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- Account Number -->
                    <div>
                        <label class="block text-sm font-semibold mb-2" style="color: #b39359;">Account Number <span class="text-red-500">*</span></label>
                        <input type="text" id="accountNumber" name="AccountNumber" placeholder="Account Number" class="w-full bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded focus:outline-none focus:border-gray-400" required />
                    </div>

                    <!-- Submit Button -->
                    <div class="pt-4">
                        <button type="submit" class="w-full px-6 py-3 rounded font-bold text-white transition-all" style="background-color: #b39359;">
                            Submit
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<input type="hidden" id="registerAffiliateUrl" value="@Url.Action("RegisterAffiliate")" />
