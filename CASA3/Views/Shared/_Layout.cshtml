<!DOCTYPE html>
<html lang="en">
@{
    var isAboutUsPage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "AboutUs", StringComparison.OrdinalIgnoreCase);
}
<head>

	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />

	<title>@ViewData["Title"] - Casa III</title>

	<!-- Tailwind -->
	<script src="https://cdn.tailwindcss.com"></script>

	<!-- Icons -->
	<link rel="stylesheet" href="~/css/font-awesome.min.css" />
	<link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">

	<!-- SweetAlert -->
	<link rel="stylesheet" href="~/css/sweetalert2.min.css" />

	<!-- Fonts -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

	<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville&family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<!-- jQuery -->
	<script src="~/js/jquery-3.5.1.min.js"></script>
	<script src="~/js/jquery-ui.min.js"></script>
	<script src="~/js/jquery.ui.touch-punch.min.js"></script>

	<!-- Core -->
	<script src="~/js/popper.min.js"></script>
	<script src="~/js/sweetalert2.all.min.js"></script>
	<script src="~/js/common.js"></script>
	<script src="~/js/account.js"></script>

</head>

<body class="flex flex-col min-h-screen text-gray-800">

	<!-- ================= HEADER ================= -->

	<header id="siteHeader" class="bg-transparent border-b sticky top-0 z-50 transition-all duration-300">

		<div class="max-w-7xl mx-auto px-4">

			<div class="flex justify-between items-center h-16">

				<!-- Logo -->

				<a asp-controller="Home" asp-action="Index" class="flex items-center">

					<img id="siteLogo" src="~/images/CASALOGONEW.png" class="h-14 transition-all duration-300 rounded-lg" />

				</a>

				<!-- Desktop Navigation -->

				<nav class="hidden md:flex items-center space-x-6 text-sm font-medium">

					<a asp-controller="Home" asp-action="AboutUs" class="nav-deep-navy">About Us</a>

					<div class="relative group">

						<a asp-controller="Home" asp-action="OurProject" class="flex items-center gap-1 nav-deep-navy">

							Our Projects <i class="fa fa-chevron-down text-xs"></i>

						</a>

						<div class="absolute left-0 top-full w-full h-2"></div>

						<div class="absolute left-0 top-full pt-2 w-56 bg-white shadow-xl border border-gray-200 rounded-lg

opacity-0 invisible translate-y-3
group-hover:opacity-100 group-hover:visible group-hover:translate-y-0
transition-all duration-300
max-h-96 overflow-y-auto z-50">

							@await Component.InvokeAsync("Navigation")

						</div>

					</div>

					<a asp-controller="Client" asp-action="Register" class="nav-deep-navy">Client Registration</a>

					<a asp-controller="Home" asp-action="BecomeAnAffiliate" class="nav-deep-navy">Become An Affiliate</a>

					<a href="/Become-A-Vendor" class="nav-deep-navy">Become A Vendor</a>

					<a asp-controller="Home" asp-action="ContactUs" class="nav-deep-navy">Contact Us</a>

					<a asp-controller="Home" asp-action="Blog" class="nav-deep-navy">Blog</a>

				</nav>

				<!-- Mobile Button -->

				<button id="mobileMenuBtn" class="md:hidden text-2xl">

					<i class="fa fa-bars"></i>

				</button>

			</div>

		</div>

		<!-- Mobile Menu -->
		<div id="mobileMenu"
			 class="hidden md:hidden absolute top-16 left-0 w-full bg-white shadow-lg border-t z-50">

			<div class="px-6 py-6 space-y-4 text-base font-medium">

				<a asp-controller="Home" asp-action="AboutUs" class="block">About Us</a>

				<details>
					<summary class="cursor-pointer">Our Projects</summary>

					<div class="ml-4 mt-2 space-y-2">
						@await Component.InvokeAsync("Navigation")
					</div>
				</details>

				<a asp-controller="Client" asp-action="Register" class="block">Client Registration</a>

				<a asp-controller="Home" asp-action="BecomeAnAffiliate" class="block">Become An Affiliate</a>

				<a href="/Become-A-Vendor" class="block">Become A Vendor</a>

				<a asp-controller="Home" asp-action="ContactUs" class="block">Contact Us</a>

				<a asp-controller="Home" asp-action="Blog" class="block">Blog</a>

			</div>

		</div>
	</header>

	<!-- ================= MAIN ================= -->

	<main class="flex-grow">

		@RenderBody()

	</main>

	<!-- ================= FOOTER ================= -->

	<footer class="bg-gray-100 mt-20">

		<section class="relative flex footer-bg">

			<div class="w-full lg:w-2/3 py-16 lg:py-20 footer-content">

				<div class="max-w-4xl mx-auto px-6 lg:px-12">

					<div class="mb-8 text-center">

						<h2 class="inline-block border border-white text-white px-10 py-4 text-2xl md:text-3xl lg:text-4xl font-semibold tracking-widest uppercase">

							Experience the CASA III Edge

						</h2>

					</div>

					<div class="flex items-center justify-between mb-12 text-white">

						<div class="flex items-center gap-4 text-2xl">

							<a href="https://web.facebook.com/profile.php?id=61587713982691" target="_blank">

								<i class="fa fa-facebook"></i>

							</a>

							<a href="https://www.instagram.com/thecasaiii" target="_blank">

								<i class="fa fa-instagram"></i>

							</a>

							<a href="https://www.linkedin.com/company/casaiii" target="_blank">

								<i class="fa fa-linkedin"></i>

							</a>

							<a href="https://x.com/thecasaiii" target="_blank">

								<i class="fa fa-twitter"></i>

							</a>

						</div>

						<span class="w-px h-8 bg-white"></span>

						<div class="flex items-center gap-2 font-medium">

							<i class="fa fa-phone"></i>

							<span>(+234) 8108333303</span>

						</div>

					</div>

					<form asp-controller="Home" asp-action="SubscribeNewsletter" method="post" class="flex flex-col gap-3">

						<input type="email"
							   name="Email"
							   placeholder="Enter your email address"
							   class="w-full border-2 border-[#b39359] bg-white px-4 py-3" />

						<button type="submit"
								class="w-1/2 mx-auto bg-black text-white px-8 py-3 font-medium hover:bg-[#b39359] rounded-lg">

							Subscribe

						</button>

					</form>

				</div>

			</div>

			<div class="hidden lg:block w-1/3 relative">

				<div class="absolute inset-0 bg-black/20"></div>

			</div>

		</section>

		@await Component.InvokeAsync("Partners")

		<div class="bg-gray-200 py-6">

			<div class="max-w-7xl mx-auto px-4 text-sm">

				<div class="hidden md:flex items-center relative">

					<img src="~/images/CASALOGONEW.png" class="h-12 rounded-lg" />

					<p class="absolute left-1/2 -translate-x-1/2 text-center font-bold text-gray-400">

						© No. 22, Mambilla Street, Aso Drive, Abuja

					</p>

				</div>

			</div>

		</div>

	</footer>

	<!-- Scripts -->

	<script>
		var mobileMenuBtn = document.getElementById("mobileMenuBtn");
		if (mobileMenuBtn) {
			mobileMenuBtn.onclick = function () {
				var menu = document.getElementById("mobileMenu");
				if (menu) menu.classList.toggle("hidden");
			};
		}

		window.addEventListener("scroll", function () {
			var header = document.getElementById("siteHeader");
			var logo = document.getElementById("siteLogo");
			if (!header || !logo) return;
			if (window.scrollY > 50) {
				header.classList.remove("bg-transparent");
				header.classList.add("bg-white", "shadow-md");
				logo.classList.remove("h-14");
				logo.classList.add("h-11");
			} else {
				header.classList.remove("bg-white", "shadow-md");
				header.classList.add("bg-transparent");
				logo.classList.remove("h-11");
				logo.classList.add("h-14");
			}
		});
	</script>

	<script>
		/* Partners Slider - runs after page and images load */
		window.addEventListener("load", function () {
			var partnersSlider = document.getElementById("partnersSlider");
			if (!partnersSlider) return;

			var logos = partnersSlider.querySelectorAll(".partner-logo");
			if (logos.length === 0) return;

			var partnersCount = parseInt(partnersSlider.getAttribute("data-partners-count"), 10) || 1;
			var currentIndex = 0;

			function getScrollAmount() {
				var first = logos[0];
				if (!first) return 0;
				var logoWidth = first.offsetWidth || 160;
				var gap = window.innerWidth >= 1024 ? 80 : window.innerWidth >= 768 ? 64 : 48;
				return logoWidth + gap;
			}

			function scrollPartners() {
				var scrollAmount = getScrollAmount();
				if (scrollAmount <= 0) return;
				currentIndex++;

				if (currentIndex >= partnersCount) {
					currentIndex = 0;
					partnersSlider.style.transition = "none";
					partnersSlider.style.transform = "translateX(0)";
					partnersSlider.offsetHeight;
					partnersSlider.style.transition = "transform 0.8s ease-in-out";
				} else {
					partnersSlider.style.transition = "transform 0.8s ease-in-out";
					partnersSlider.style.transform = "translateX(-" + (scrollAmount * currentIndex) + "px)";
				}
			}

			if (partnersCount > 0 && logos.length > 0) {
				setInterval(scrollPartners, 3000);
			}
		});
	</script>

	<script src="~/js/site.js"></script>
	<script src="~/js/scroll-effects.js"></script>

	@RenderSection("Scripts", required: false)

</body>

</html>