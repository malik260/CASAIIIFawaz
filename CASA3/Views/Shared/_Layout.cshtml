@{
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    var action = ViewContext.RouteData.Values["Action"]?.ToString();
    var isAboutUsPage = controller == "Home" && action == "AboutUs";
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Casa III</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Icons -->
    <link rel="stylesheet" href="~/css/font-awesome.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">

    <!-- Sweetalert -->
    <link rel="stylesheet" href="~/css/sweetalert2.min.css" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville&family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- jQuery -->
    <script src="~/js/jquery-3.5.1.min.js"></script>
    <script src="~/js/jquery-ui.min.js"></script>
    <script src="~/js/jquery.ui.touch-punch.min.js"></script>

    <!-- Core JS -->
    <script src="~/js/popper.min.js"></script>
    <script src="~/js/sweetalert2.all.min.js"></script>
    <script src="~/js/sweetalert.min.js"></script>
    <script src="~/js/common.js" asp-append-version="true"></script>
    <script src="~/js/account.js" asp-append-version="true"></script>

    <script>

        function errorAlert(message){
        Swal.fire({
        icon:'error',
        text:message,
        confirmButtonColor:"#1E403F",
        timer:30000
        })
        }

        function infoAlert(message){
        Swal.fire({
        icon:'info',
        text:message,
        confirmButtonColor:"#1E403F"
        })
        }

        function successAlert(message){
        Swal.fire({
        icon:'success',
        text:message,
        timer:60000,
        confirmButtonColor:"#FF9B44"
        })
        }

        function successAlertWithRedirect(message,url){

        Swal.fire({
        title:"Success",
        text:message,
        icon:"success",
        timer:30000,
        confirmButtonColor:"#1E403F"
        }).then(function(){
        location.href=url
        })

        }

    </script>

</head>

<body class="flex flex-col min-h-screen text-gray-800">

    <!-- ================= HEADER ================= -->

    <header class="bg-white border-b sticky top-0 z-50">

        <div class="max-w-7xl mx-auto px-4">

            <div class="flex justify-between items-center h-16">

                <!-- Logo -->

                <a asp-controller="Home" asp-action="Index" class="flex items-center">

                    <img src="~/images/CASA III PNG.png" class="h-11 md:h-13 rounded-lg" />

                </a>

                <!-- Desktop Menu -->

                <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">

                    <a asp-controller="Home" asp-action="AboutUs" class="nav-deep-navy">About Us</a>

                    <div class="relative group">

                        <a asp-controller="Home" asp-action="OurProject" class="flex items-center gap-1 nav-deep-navy">

                            Our Projects <i class="fa fa-chevron-down text-xs"></i>

                        </a>

                        <div class="absolute left-0 top-full w-full h-2"></div>

                        <div class="absolute left-0 top-full pt-2 w-56 bg-white shadow-xl border border-gray-200 rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 max-h-96 overflow-y-auto z-50">

                            @await Component.InvokeAsync("Navigation")

                        </div>

                    </div>

                    <a asp-controller="Client" asp-action="Register" class="nav-deep-navy">Client Registration</a>

                    <a asp-controller="Home" asp-action="BecomeAnAffiliate" class="nav-deep-navy">Become An Affiliate</a>

                    <a href="/Become-A-Vendor" class="nav-deep-navy">Become A Vendor</a>

                    <a asp-controller="Home" asp-action="ContactUs" class="nav-deep-navy">Contact Us</a>

                    <a asp-controller="Home" asp-action="Blog" class="nav-deep-navy">Blog</a>

                </nav>

                <!-- Mobile Button -->

                <button id="mobileMenuBtn" class="md:hidden text-2xl">

                    <i class="fa fa-bars"></i>

                </button>

            </div>

        </div>

        <!-- Mobile Menu -->

        <div id="mobileMenu" class="hidden md:hidden border-t bg-white">

            <div class="px-4 py-4 space-y-3 text-sm">

                <a asp-controller="Home" asp-action="AboutUs">About Us</a>

                <details>

                    <summary>Our Projects</summary>

                    <div class="ml-4 mt-2 space-y-2">

                        @await Component.InvokeAsync("Navigation")

                    </div>

                </details>

                <a asp-controller="Client" asp-action="Register">Client Registration</a>

                <a asp-controller="Home" asp-action="BecomeAnAffiliate">Become An Affiliate</a>

                <a href="/Become-A-Vendor">Become A Vendor</a>

                <a asp-controller="Home" asp-action="ContactUs">Contact Us</a>

                <a asp-controller="Home" asp-action="Blog">Blog</a>

            </div>

        </div>

    </header>

    <!-- ================= MAIN ================= -->

    <main class="flex-grow">

        @RenderBody()

    </main>

    <!-- ================= FOOTER ================= -->

    <footer class="bg-gray-100 mt-20">

        <section class="relative flex bg-cover bg-center"
                 style="background-image:url('/images/@(isAboutUsPage ? "SIDE ELEVATION.png" : "STREET-VIEW.webp")');">

            <div class="w-full lg:w-2/3 py-16 lg:py-20">

                <div class="max-w-4xl mx-auto px-6 lg:px-12">

                    <div class="mb-8 text-center">

                        <h2 class="inline-block border px-10 py-4 text-2xl md:text-3xl lg:text-4xl font-semibold tracking-widest uppercase @(isAboutUsPage ? "border-gray-900 text-gray-900 bg-white/70" : "border-white text-white")">

                            Experience the CASA III Edge

                        </h2>

                    </div>

                    <div class="flex items-center justify-between mb-12">

                        <div class="flex items-center gap-4 text-2xl @(isAboutUsPage ? "text-gray-900" : "text-white")">

                            <a href="https://web.facebook.com/profile.php?id=61587713982691" target="_blank">

                                <i class="fa fa-facebook"></i>

                            </a>

                            <a href="https://www.instagram.com/thecasaiii" target="_blank">

                                <i class="fa fa-instagram"></i>

                            </a>

                            <a href="https://www.linkedin.com/company/casaiii" target="_blank">

                                <i class="fa fa-linkedin"></i>

                            </a>

                            <a href="https://x.com/thecasaiii" target="_blank">

                                <i class="fa fa-twitter"></i>

                            </a>

                        </div>

                        <span class="w-px h-8 bg-gray-800"></span>

                        <div class="flex items-center gap-2 font-medium @(isAboutUsPage ? "text-gray-900" : "text-white")">

                            <i class="fa fa-phone"></i>

                            <span>(+234) 8108333303</span>

                        </div>

                    </div>

                    <form asp-controller="Home" asp-action="SubscribeNewsletter" method="post" class="flex flex-col gap-3">

                        <input type="email"
                               name="Email"
                               placeholder="Enter your email address"
                               class="w-full border-2 border-[#b39359] bg-white px-4 py-3" />

                        <button type="submit"
                                class="w-1/2 mx-auto bg-black text-white px-8 py-3 font-medium hover:bg-[#b39359] rounded-lg">

                            Subscribe

                        </button>

                    </form>

                </div>

            </div>

            <div class="hidden lg:block w-1/3 relative">

                <div class="absolute inset-0 bg-black/10"></div>

            </div>

        </section>

        @await Component.InvokeAsync("Partners")

        <div class="bg-gray-200 py-6">

            <div class="max-w-7xl mx-auto px-4 text-sm">

                <div class="hidden md:flex items-center relative">

                    <img src="~/images/CASA III PNG.png" class="h-12 rounded-lg" />

                    <p class="absolute left-1/2 -translate-x-1/2 text-center font-bold text-gray-400">

                        © No. 22, Mambilla Street, Aso Drive, Abuja

                    </p>

                </div>

            </div>

        </div>

    </footer>

    <script>

        document.getElementById("mobileMenuBtn").onclick=()=>{

        document.getElementById("mobileMenu").classList.toggle("hidden")

        }

    </script>

    <script src="~/js/site.js"></script>
    <script src="~/js/scroll-effects.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>